# ── Recherche (paramètres par défaut du scraping) ──

# Mots-clés de recherche, séparés par des virgules (OBLIGATOIRE — sans cette variable, le scrape échoue)
DEFAULT_SEARCH_KEYWORDS=développeur frontend,react,typescript

# Ville ou région pour cibler les offres (recommandé)
DEFAULT_SEARCH_LOCATION=Paris

# Rayon de recherche en km autour de la localisation (défaut : 50)
DEFAULT_SEARCH_RADIUS_KM=50

# ── Base de données ──

# Chemin du fichier SQLite (défaut : ./data/jobs.db)
DATABASE_PATH=./data/jobs.db

# ── Serveur ──

# Port d'écoute (défaut : 3000)
PORT=3000
NODE_ENV=production

# ── Navigateur ──

# Mettre à "false" pour voir le navigateur Chromium pendant le scraping (utile en dev)
# BROWSER_HEADLESS=false
